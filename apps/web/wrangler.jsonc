// Assets-only Worker: no server code, wrangler uploads ./dist as static assets.
// Deployed URL: https://lordly.<account-subdomain>.workers.dev
{
  "name": "lordly",
  "compatibility_date": "2026-07-12",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
